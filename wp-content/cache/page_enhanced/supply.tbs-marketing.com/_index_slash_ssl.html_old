		<style id="wp-custom-css">
			/* กำหนดขนาดและพื้นหลัง Sidebar */
#nav_menu-3.widget_nav_menu {
  background-color: #15a5da !important; 
  padding: 30px !important;
  width: 270px !important;
  box-sizing: border-box;
}


/* ปรับหัวข้อ Sidebar */
#nav_menu-3.widget_nav_menu .widget-title {
  color: #fff;
  font-weight: 800px;
  font-size: 30px;
  margin-bottom: 30px;
	margin-top: 20px;
	
	text-align: center;
	display: block;
	
}

/* ลบจุดหัวข้อในเมนู */
#nav_menu-3.widget_nav_menu ul {
  list-style: none;
  padding-left: 0;
}

/* สไตล์ลิงก์เมนู */
#nav_menu-3.widget_nav_menu ul li a {
  display: flex;
  align-items: center;
  color: #fff;
  font-weight: 600;
  font-size: 17px;
  padding: 10px 15px;
  text-decoration: none;
  border-radius: 5px;
  margin-bottom: 8px;
  transition: background-color 0.3s ease;
}

#nav_menu-3.widget_nav_menu ul li a {
  display: flex;            /* จัดไอคอนและข้อความเป็นแถวเดียว */
  align-items: center;      /* จัดกึ่งกลางแนวตั้ง */
  gap: 10px;                /* ระยะห่างระหว่างไอคอนกับข้อความ */
  padding: 10px 15px;
  color: white;
  font-weight: 600;
  font-size: 18px;
  text-decoration: none;
  border-radius: 5px;
  transition: background-color 0.3s ease;
}

/* สีพื้นหลังเวลา hover หรือหน้าเมนูที่เลือก */
#nav_menu-3.widget_nav_menu ul li.current-menu-item > a,
#nav_menu-3.widget_nav_menu ul li a:hover {
  background-color: #006C94;
  color: #fff;
}

#nav_menu-3.widget_nav_menu ul li a i {
  font-size: 20px !important;
  min-width: 24px !important;
  text-align: center !important;
  color: white !important;
